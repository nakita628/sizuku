{
  "name": "sizuku",
  "version": "0.6.1",
  "description": "Sizuku is a tool that generates validation schemas for Zod and Valibot, as well as ER diagrams and DBML, from Drizzle schemas annotated with comments.",
  "keywords": [
    "dbml",
    "drizzle",
    "mermaid",
    "valibot",
    "zod"
  ],
  "homepage": "https://github.com/nakita628/sizuku",
  "bugs": {
    "url": "https://github.com/nakita628/sizuku/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nakita628/sizuku.git"
  },
  "bin": {
    "sizuku": "dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {},
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vp test",
    "coverage": "vp test --coverage",
    "release": "npm pkg fix && pnpm build && npm publish"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@softwaretechnik/dbml-renderer": "^1.0.31",
    "oxfmt": "^0.42.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-orm": "^0.45.1",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2",
    "valibot": "1.3.1"
  }
}
