Table user {
  id text [pk, note: 'Primary key']
  name text [note: 'name']
  email text [note: 'email']
  emailVerified boolean [note: 'emailVerified']
  image text [note: 'image']
  createdAt timestamp [note: 'createdAt']
  updatedAt timestamp [note: 'updatedAt']
  twoFactorEnabled boolean [note: 'twoFactorEnabled']
  role text [note: 'role']
  banned boolean [note: 'banned']
  banReason text [note: 'banReason']
  banExpires timestamp [note: 'banExpires']
  username text [note: 'username']
  displayUsername text [note: 'displayUsername']
  isAnonymous boolean [note: 'isAnonymous']
  phoneNumber text [note: 'phoneNumber']
  phoneNumberVerified boolean [note: 'phoneNumberVerified']
}

Table session {
  id text [pk, note: 'Primary key']
  expiresAt timestamp [note: 'expiresAt']
  token text [note: 'token']
  createdAt timestamp [note: 'createdAt']
  updatedAt timestamp [note: 'updatedAt']
  ipAddress text [note: 'ipAddress']
  userAgent text [note: 'userAgent']
  userId text [note: 'userId']
  activeOrganizationId text [note: 'activeOrganizationId']
  impersonatedBy text [note: 'impersonatedBy']
}

Table account {
  id text [pk, note: 'Primary key']
  accountId text [note: 'accountId']
  providerId text [note: 'providerId']
  userId text [note: 'userId']
  accessToken text [note: 'accessToken']
  refreshToken text [note: 'refreshToken']
  idToken text [note: 'idToken']
  accessTokenExpiresAt timestamp [note: 'accessTokenExpiresAt']
  refreshTokenExpiresAt timestamp [note: 'refreshTokenExpiresAt']
  scope text [note: 'scope']
  password text [note: 'password']
  createdAt timestamp [note: 'createdAt']
  updatedAt timestamp [note: 'updatedAt']
}

Table verification {
  id text [pk, note: 'Primary key']
  identifier text [note: 'identifier']
  value text [note: 'value']
  expiresAt timestamp [note: 'expiresAt']
  createdAt timestamp [note: 'createdAt']
  updatedAt timestamp [note: 'updatedAt']
}

Table twoFactor {
  id text [pk, note: 'Primary key']
  secret text [note: 'secret']
  backupCodes text [note: 'backupCodes']
  userId text [note: 'userId']
}

Table organization {
  id text [pk, note: 'Primary key']
  name text [note: 'name']
  slug text [note: 'slug']
  logo text [note: 'logo']
  createdAt timestamp [note: 'createdAt']
  metadata text [note: 'metadata']
}

Table member {
  id text [pk, note: 'Primary key']
  organizationId text [note: 'organizationId']
  userId text [note: 'userId']
  role text [note: 'role']
  createdAt timestamp [note: 'createdAt']
}

Table invitation {
  id text [pk, note: 'Primary key']
  organizationId text [note: 'organizationId']
  email text [note: 'email']
  role text [note: 'role']
  status text [note: 'status']
  expiresAt timestamp [note: 'expiresAt']
  createdAt timestamp [note: 'createdAt']
  inviterId text [note: 'inviterId']
}

Table jwks {
  id text [pk, note: 'Primary key']
  publicKey text [note: 'publicKey']
  privateKey text [note: 'privateKey']
  createdAt timestamp [note: 'createdAt']
  expiresAt timestamp [note: 'expiresAt']
}

Table deviceCode {
  id text [pk, note: 'Primary key']
  deviceCode text [note: 'deviceCode']
  userCode text [note: 'userCode']
  userId text [note: 'userId']
  expiresAt timestamp [note: 'expiresAt']
  status text [note: 'status']
  lastPolledAt timestamp [note: 'lastPolledAt']
  pollingInterval integer [note: 'pollingInterval']
  clientId text [note: 'clientId']
  scope text [note: 'scope']
}

Ref session_userId_user_id_fk: session.userId > user.id

Ref account_userId_user_id_fk: account.userId > user.id

Ref twoFactor_userId_user_id_fk: twoFactor.userId > user.id

Ref member_organizationId_organization_id_fk: member.organizationId > organization.id

Ref member_userId_user_id_fk: member.userId > user.id

Ref invitation_organizationId_organization_id_fk: invitation.organizationId > organization.id

Ref invitation_inviterId_user_id_fk: invitation.inviterId > user.id